# PEAK Assistant environment variables
#
# Copy this file to .env and uncomment the variables for the provider(s)
# referenced in your model_config.json. You only need the section(s) that
# match your configured provider(s).
#
#   cp .env.example .env
#

# For OpenAI
OPENAI_API_KEY=your_key_here

# For Anthropic
# ANTHROPIC_API_KEY=your_key_here

# For Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_API_VERSION=YYYY-MM-DD-preview
