# PEAK Assistant environment variables
#
# Copy this file to .env and uncomment the variables for the provider(s)
# referenced in your model_config.json. You only need the section(s) that
# match your configured provider(s).
#
#   cp .env.example .env
#

# For OpenAI
OPENAI_API_KEY=your_key_here

# For Anthropic
# ANTHROPIC_API_KEY=your_key_here

# For Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_API_VERSION=YYYY-MM-DD-preview

# Custom auth modules (required if model_config.json uses auth_module)
# Comma-separated list of exact module names or package prefixes (e.g. my_auth.plugins.*)
# Leave empty or unset to deny all custom auth module loading (secure default).
# PEAK_AUTH_MODULE_ALLOWLIST=private_auth.circuit_oauth
